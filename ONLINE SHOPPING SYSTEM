--5)Handle NO_DATA_FOUND exception in a simple block.
DECLARE
    V_PRICE PRODUCTS.PRICE%TYPE;
BEGIN
    SELECT PRICE INTO V_PRICE
    FROM PRODUCTS
    WHERE PRODUCT_ID = 100;

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('No data found');
END;

--6)Write a PL/SQL block to display product name using prod_id.
