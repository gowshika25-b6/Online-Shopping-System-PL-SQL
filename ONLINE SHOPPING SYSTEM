END;

--15)Handle error when product not found using prod_id.
DECLARE
    V_PRICE PRODUCTS.PRICE%TYPE;
BEGIN
    SELECT PRICE INTO V_PRICE
    FROM PRODUCTS
    WHERE PRODUCT_ID = 10;

    DBMS_OUTPUT.PUT_LINE('PRICE = ' || V_PRICE);

