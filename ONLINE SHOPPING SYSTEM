--8)Display total number of products in PRODUCTS.
DECLARE 
    V_TOTAL NUMBER;
BEGIN
    SELECT COUNT(*) INTO V_TOTAL FROM PRODUCTS;
    DBMS_OUTPUT.PUT_LINE('TOTAL_PRODUCTS='||V_TOTAL);
END;
/

--9)Check if product price > 1000 → print "Expensive".
DECLARE
    V_PRICE PRODUCTS.PRICE%TYPE;
BEGIN
    SELECT PRICE INTO V_PRICE FROM PRODUCTS
    WHERE PRODUCT_ID=4;
    IF V_PRICE>1000 THEN
    DBMS_OUTPUT.PUT_LINE('EXPENSIVE='||V_PRICE);
    ELSE
    DBMS_OUTPUT.PUT_LINE('AFFORDABLE='||V_PRICE);
    END IF;
END;
/

--10)Display all product IDs using loop.
BEGIN
    FOR I IN(SELECT PRODUCT_ID FROM PRODUCTS) LOOP
    DBMS_OUTPUT.PUT_LINE('PRODUCT_ID='||I.PRODUCT_ID);
    END LOOP;
END;

--11)Use cursor to display product names.
BEGIN
    FOR REC IN (SELECT PRODUCT_NAME FROM PRODUCTS) LOOP
        DBMS_OUTPUT.PUT_LINE(REC.PRODUCT_NAME);
    END LOOP;
END;

--12)Display order_id and quantity using cursor.
BEGIN
    FOR REC IN (SELECT ORDER_ID,QUANTITY FROM ORDERS) LOOP
        DBMS_OUTPUT.PUT_LINE('ORDER ID='|| REC.ORDER_ID||'QUANTITY='||REC.QUANTITY);
    END LOOP;
END;

--13Insert a new product using PL/SQL block.
DECLARE
    V_PRODUCT_ID PRODUCTS.PRODUCT_ID%TYPE;
    V_PRODUCT_NAME PRODUCTS.PRODUCT_NAME%TYPE;
    V_PRICE PRODUCTS.PRICE%TYPE;
BEGIN
    V_PRODUCT_ID:=5;
    V_PRODUCT_NAME:='TAB';
    V_PRICE:=50000;
    INSERT INTO PRODUCTS
    (PRODUCT_ID,PRODUCT_NAME,PRICE) VALUES (V_PRODUCT_ID,V_PRODUCT_NAME,V_PRICE);
    COMMIT;
END;
/

--14)Update price using prod_id.
BEGIN
    UPDATE PRODUCTS
    SET PRICE = 1500
    WHERE PRODUCT_ID = 1;

